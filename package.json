{
  "name": "litedbmodel-gen",
  "version": "0.1.2",
  "description": "embedoc-based model code generator for litedbmodel — generates TypeScript column definitions from SQL DDL (PostgreSQL/MySQL/SQLite)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "litedbmodel-gen": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "docs",
    "cli-contract.yaml"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "litedbmodel",
    "embedoc",
    "code-generator",
    "orm",
    "postgresql",
    "mysql",
    "sqlite",
    "ddl",
    "schema"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "node-sql-parser": "^5.4.0"
  },
  "peerDependencies": {
    "embedoc": ">=0.11.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "cli-contracts": "^0.2.0",
    "embedoc": "^0.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
