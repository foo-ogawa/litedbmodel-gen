{
  "name": "litedbmodel-gen",
  "version": "0.7.12",
  "description": "embedoc-based model code generator for litedbmodel — generates TypeScript column definitions from SQL DDL (PostgreSQL/MySQL/SQLite)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "litedbmodel-gen": "dist/litedbmodel-gen.bundle.mjs"
  },
  "files": [
    "dist/litedbmodel-gen.bundle.mjs",
    "dist/litedbmodel-gen.bundle.mjs.map",
    "dist",
    "templates",
    "docs",
    "cli-contract.yaml"
  ],
  "scripts": {
    "build": "tsup",
    "bundle": "node esbuild.bundle.mjs",
    "bundle:min": "node esbuild.bundle.mjs --minify",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run bundle:min && npm run test:ci",
    "cli:generate": "cli-contracts generate",
    "dsl:generate": "agent-runtime generate --config dsl/agent-runtime.config.yaml",
    "test:ci": "vitest run"
  },
  "keywords": [
    "litedbmodel",
    "embedoc",
    "code-generator",
    "orm",
    "postgresql",
    "mysql",
    "sqlite",
    "ddl",
    "schema"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "agent-contracts": "^0.34.11",
    "agent-contracts-runtime": "^0.36.4",
    "cli-contracts": "^0.32.0",
    "commander": "^14.0.3",
    "embedoc": "^0.11.0",
    "esbuild": "^0.28.0",
    "js-yaml": "^4.1.2",
    "node-sql-parser": "^5.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "overrides": {
    "js-yaml": "^4.1.2"
  }
}
