{
  "name": "litedbmodel-gen",
  "version": "0.5.0",
  "description": "embedoc-based model code generator for litedbmodel — generates TypeScript column definitions from SQL DDL (PostgreSQL/MySQL/SQLite)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "litedbmodel-gen": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "docs",
    "cli-contract.yaml"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "cli:generate": "cli-contracts generate",
    "dsl:generate": "agent-runtime generate --config dsl/agent-runtime.config.yaml"
  },
  "keywords": [
    "litedbmodel",
    "embedoc",
    "code-generator",
    "orm",
    "postgresql",
    "mysql",
    "sqlite",
    "ddl",
    "schema"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "node-sql-parser": "^5.4.0"
  },
  "peerDependencies": {
    "embedoc": ">=0.11.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@openai/agents": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    },
    "@cursor/sdk": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.2.0",
    "@google/genai": ">=2.0.0",
    "@openai/agents": ">=0.10.0"
  },
  "devDependencies": {
    "@cursor/sdk": "^1.0.16",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "agent-contracts": "^0.32.0",
    "agent-contracts-runtime": "^0.32.1",
    "cli-contracts": "^0.31.6",
    "embedoc": "^0.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0",
    "vitest": "^4.1.7",
    "zod": "^4.0.0"
  }
}
